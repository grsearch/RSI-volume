# ── API Keys ─────────────────────────────────────────────────────
BIRDEYE_API_KEY=
HELIUS_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_KEY
HELIUS_API_KEY=
HELIUS_WSS_URL=wss://atlas-mainnet.helius-rpc.com/?api-key=YOUR_KEY   # Enhanced WebSocket URL（从 Helius Dashboard 复制）
JUPITER_API_URL=https://api.jup.ag
JUPITER_API_KEY=

# ── 钱包 ─────────────────────────────────────────────────────────
WALLET_PRIVATE_KEY=          # Base58 私钥（DRY_RUN 模式下可留空）

# ── 交易参数 ──────────────────────────────────────────────────────
TRADE_SIZE_SOL=0.2
SLIPPAGE_BPS=500
SLIPPAGE_MAX_BPS=2000
TRADE_MAX_RETRY=5
USE_JITO=false
JITO_TIP_LAMPORTS=1000000
PRIORITY_FEE_MICROLAMPORTS=100000

# ── 策略参数 ──────────────────────────────────────────────────────
RSI_PERIOD=7
RSI_BUY_LEVEL=30             # RSI 上穿此值买入
RSI_SELL_LEVEL=70            # RSI 下穿此值卖出
RSI_PANIC_LEVEL=80           # RSI 超过此值立即卖出

# ── 量能过滤参数 ──────────────────────────────────────────────────
VOL_ENABLED=true             # 是否启用量能过滤
VOL_WINDOW_SEC=30            # 买入确认窗口（秒）：窗口内 buyVol > sellVol 才买入
VOL_EXIT_CONSECUTIVE=2       # 持仓中连续N根K线量能萎缩则出场
VOL_EXIT_RATIO=1.0           # 量能萎缩阈值：当前量 < 均量 × 此值 视为萎缩
VOL_EXIT_LOOKBACK=4          # 萎缩出场均量回看K线数
SKIP_FIRST_CANDLES=8         # 跳过前N根K线不交易（15秒K线×8=2分钟）

# ── K线 & 轮询 ────────────────────────────────────────────────────
KLINE_INTERVAL_SEC=15        # K线宽度（秒）— 15秒
PRICE_POLL_SEC=1             # 价格轮询间隔（秒）

# ── 止盈止损 ──────────────────────────────────────────────────────
TAKE_PROFIT_PCT=50           # 止盈百分比
STOP_LOSS_PCT=-10            # 止损百分比（负数）

# ── 监控参数 ──────────────────────────────────────────────────────
TOKEN_MAX_AGE_MINUTES=15
FDV_EXIT_USD=10000
MIN_FDV_USD=15000
MIN_LP_USD=5000

# ── 空跑模式 ──────────────────────────────────────────────────────
DRY_RUN=true                 # true=不实际交易，只记录信号和模拟盈亏
DRY_RUN_DATA_DIR=./data      # 空跑数据持久化目录

# ── 服务器 ────────────────────────────────────────────────────────
PORT=3001
LOG_LEVEL=info
