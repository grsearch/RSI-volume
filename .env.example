# ── 기본 설정 ────────────────────────────────────────────────────
DRY_RUN=true                 # 공매도 모드（true=시뮬레이션, false=실거래）
HELIUS_WSS_URL=wss://atlas-mainnet.helius-rpc.com/?api-key=YOUR_KEY
BIRDEYE_API_KEY=YOUR_KEY

# ── 거래 설정 ────────────────────────────────────────────────────
TRADE_SIZE_SOL=0.2
TRADE_COOLDOWN_SEC=60        # 매도 후 재매수 대기（초）

# ── 모니터링 설정 ────────────────────────────────────────────────
TOKEN_MAX_AGE_MINUTES=60     # 모니터링 시간（분）
PRICE_POLL_SEC=1             # 폴링 주기（초）
KLINE_INTERVAL_SEC=15        # K선 주기（초）
SKIP_FIRST_CANDLES=3         # 초기 K선 스킵

# ── RSI 설정 ─────────────────────────────────────────────────────
RSI_PERIOD=7
RSI_BUY_LEVEL=35
RSI_SELL_LEVEL=70
RSI_PANIC_LEVEL=80

# ── 量能 설정 ─────────────────────────────────────────────────────
VOL_ENABLED=true
VOL_WINDOW_SEC=60            # 量能 집계 윈도우（초）
VOL_EXIT_CONSECUTIVE=4       # 연속 N개 K선 萎缩 시 退出
VOL_EXIT_LOOKBACK=6          # 균량 계산 기준 K선 수
VOL_EXIT_RATIO=0.5           # 均量의 X배 이하 시 萎缩

# ── 止損 설정 ─────────────────────────────────────────────────────
STOP_LOSS_PCT=-10

# ── FDV/LP 퇴출 설정 ─────────────────────────────────────────────
FDV_EXIT_USD=10000           # FDV 퇴출 임계값
LP_EXIT_USD=5000             # LP 퇴출 임계값

# ── 서버 ─────────────────────────────────────────────────────────
PORT=3001
