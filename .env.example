# ── API Keys ─────────────────────────────────────────────────────
BIRDEYE_API_KEY=
HELIUS_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_KEY
HELIUS_API_KEY=
HELIUS_WSS_URL=wss://atlas-mainnet.helius-rpc.com/?api-key=YOUR_KEY   # Enhanced WebSocket URL（从 Helius Dashboard 复制）
JUPITER_API_URL=https://api.jup.ag
JUPITER_API_KEY=

# ── 钱包 ─────────────────────────────────────────────────────────
WALLET_PRIVATE_KEY=          # Base58 私钥（DRY_RUN 模式下可留空）

# ── 交易参数 ──────────────────────────────────────────────────────
TRADE_SIZE_SOL=0.2
SLIPPAGE_BPS=500
SLIPPAGE_MAX_BPS=2000
TRADE_MAX_RETRY=5
USE_JITO=false
JITO_TIP_LAMPORTS=1000000
PRIORITY_FEE_MICROLAMPORTS=100000

# ── 策略参数 ──────────────────────────────────────────────────────
RSI_PERIOD=7
RSI_BUY_LEVEL=35             # RSI(7) ≤ 此值买入
# RSI_SELL_LEVEL=70          # 已弃用（卖出改为量能判断）
# RSI_PANIC_LEVEL=80         # 已弃用（卖出改为量能判断）

# ── 量能过滤参数 ──────────────────────────────────────────────────
VOL_ENABLED=true             # 是否启用量能过滤
VOL_WINDOW_SEC=60            # 量能窗口（秒）— 1分钟
# VOL_EXIT_CONSECUTIVE=2     # 已弃用（卖出改为量能判断）
# VOL_EXIT_RATIO=1.0         # 已弃用
# VOL_EXIT_LOOKBACK=4        # 已弃用
SKIP_FIRST_CANDLES=3         # 跳过前N根K线不交易（5秒K线×3=15秒）

# ── K线 & 轮询 ────────────────────────────────────────────────────
KLINE_INTERVAL_SEC=15        # K线宽度（秒）— 15秒
PRICE_POLL_SEC=1             # 价格轮询间隔（秒）

# ── 止盈止损 ──────────────────────────────────────────────────────
# TAKE_PROFIT_PCT=50         # 已弃用（卖出改为量能判断）
# STOP_LOSS_PCT=-10          # 已弃用（卖出改为量能判断）

# ── 监控参数 ──────────────────────────────────────────────────────
TOKEN_MAX_AGE_MINUTES=60     # 监控时长60分钟
TRADE_COOLDOWN_SEC=60        # 卖出后冷却秒数，冷却期内不买入（默认60秒）
FDV_EXIT_USD=10000           # FDV低于此值立即退出监控（0=禁用）
LP_EXIT_USD=5000             # LP低于此值立即退出监控（0=禁用）
# MIN_FDV_USD 和 MIN_LP_USD 已删除，不再过滤

# ── 空跑模式 ──────────────────────────────────────────────────────
DRY_RUN=true                 # true=不实际交易，只记录信号和模拟盈亏
DRY_RUN_DATA_DIR=./data      # 空跑数据持久化目录

# ── 服务器 ────────────────────────────────────────────────────────
PORT=3001
LOG_LEVEL=info
